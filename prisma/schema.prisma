generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Account {
  email               String      @id
  name                String
  refreshToken        String      @map("refresh_token")
  status              String      @default("active")
  totalMessages       Int         @default(0) @map("total_messages")
  totalThreads        Int         @default(0) @map("total_threads")
  lastCheck           DateTime    @default(now()) @map("last_check")
  createdAt           DateTime    @default(now()) @map("created_at")
  userId              String      @map("user_id")
  autoActivityEnabled Boolean     @default(false) @map("auto_activity_enabled")
  autoActivityTarget  String?     @map("auto_activity_target")
  lastAutoActivityAt  DateTime?   @map("last_auto_activity_at")
  nextAutoActivityAt  DateTime?   @map("next_auto_activity_at")
  user                User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  driveFiles          DriveFile[]
  messages            Message[]

  @@index([userId])
  @@map("accounts")
}

model Message {
  id         String   @id
  subject    String
  from       String
  snippet    String   @db.Text
  body       String?  @db.MediumText
  receivedAt DateTime @default(now()) @map("received_at")
  accountId  String   @map("account_id")
  account    Account  @relation(fields: [accountId], references: [email], onDelete: Cascade)

  @@index([accountId])
  @@map("messages")
}

model DriveFile {
  id           String
  name         String
  mimeType     String
  size         String?
  iconLink     String?
  webViewLink  String?
  modifiedTime DateTime
  accountId    String   @map("account_id")
  createdAt    DateTime @default(now()) @map("created_at")
  folderId     String   @default("root") @map("folder_id")
  account      Account  @relation(fields: [accountId], references: [email], onDelete: Cascade)

  @@id([id, folderId])
  @@index([accountId, folderId])
  @@index([accountId])
  @@map("drive_files")
}

model User {
  id                  String            @id @default(uuid())
  email               String            @unique
  password            String?
  name                String?
  role                Role              @default(MEMBER)
  googleClientId      String?           @map("google_client_id") @db.Text
  googleClientSecret  String?           @map("google_client_secret") @db.Text
  createdAt           DateTime          @default(now()) @map("created_at")
  updatedAt           DateTime          @updatedAt @map("updated_at")
  httpClientData      String?           @map("http_client_data") @db.LongText
  heroSmsApiKey       String?           @map("hero_sms_api_key") @db.Text
  accounts            Account[]
  createdAirdropTasks AirdropTask[]
  airdrops            Airdrop[]
  apiKeys             ApiKey[]
  chatSessions        ChatSession[]
  groqCredential      GroqCredential?
  llmConsole          LlmConsole?
  quickVaultItems     QuickVaultItem[]
  telSession          TelSession?
  telegramUpdates     TelegramUpdate[]
  tempMailAccounts    TempMailAccount[]
  airdropTasks        UserAirdropTask[]
  naraWallets         NaraWallet[]
  apiStats            UserApiStats?

  @@map("users")
}

model NaraWallet {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  address     String?
  encryptedPk String   @map("encrypted_pk") @db.Text
  alias       String?
  lastBalance String?  @map("last_balance")
  lastUnit    String?  @map("last_unit")
  explorerUrl String?  @map("explorer_url") @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("nara_wallets")
}

model TelegramUpdate {
  id        BigInt   @id
  userId    String   @map("user_id")
  data      String   @db.LongText
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("telegram_updates")
}

model Airdrop {
  id              String        @id @default(uuid())
  name            String
  icon            String?
  status          String
  statusDate      DateTime?
  score           Int?
  taskType        String?
  cost            String?
  time            String?
  raise           String?
  stage           String?
  description     String?       @db.Text
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  fundsAndBackers String?       @db.LongText
  links           String?       @db.LongText
  rewardDate      String?
  rewardType      String?
  symbol          String?
  projectType     String?
  isPublic        Boolean       @default(false) @map("is_public")
  userId          String?       @map("user_id")
  publishStatus   String        @default("NONE") @map("publish_status")
  tasks           AirdropTask[]
  user            User?         @relation(fields: [userId], references: [id])

  @@index([userId], map: "airdrops_user_id_fkey")
  @@map("airdrops")
}

model AirdropTask {
  id           String            @id @default(uuid())
  title        String
  description  String?           @db.Text
  category     String
  deadline     DateTime?
  status       String            @default("Open")
  airdropId    String            @map("airdrop_id")
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")
  steps        String?           @db.LongText
  userId       String?           @map("user_id")
  airdrop      Airdrop           @relation(fields: [airdropId], references: [id], onDelete: Cascade)
  user         User?             @relation(fields: [userId], references: [id])
  userProgress UserAirdropTask[]

  @@index([airdropId], map: "airdrop_tasks_airdrop_id_fkey")
  @@index([userId], map: "airdrop_tasks_user_id_fkey")
  @@map("airdrop_tasks")
}

model UserAirdropTask {
  id          String      @id @default(uuid())
  userId      String      @map("user_id")
  taskId      String      @map("task_id")
  completed   Boolean     @default(false)
  completedAt DateTime?   @map("completed_at")
  task        AirdropTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, taskId])
  @@index([taskId], map: "user_airdrop_tasks_task_id_fkey")
  @@map("user_airdrop_tasks")
}

model ApiEndpointStats {
  id        String   @id @default(uuid())
  method    String
  path      String   @unique
  hitCount  Int      @default(0) @map("hit_count")
  lastHit   DateTime @default(now()) @map("last_hit")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("api_endpoint_stats")
}

model MaintenanceConfig {
  id        String   @id @default(uuid())
  feature   String   @unique
  label     String
  enabled   Boolean  @default(false)
  message   String?
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("maintenance_configs")
}

model GlobalConfig {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String   @db.Text
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("global_configs")
}

model GroqCredential {
  id               String   @id @default(uuid())
  userId           String   @unique @map("user_id")
  apiKey           String   @map("api_key") @db.Text
  promptTokens     Int      @default(0) @map("prompt_tokens")
  completionTokens Int      @default(0) @map("completion_tokens")
  totalTokens      Int      @default(0) @map("total_tokens")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("groq_credentials")
}

model ChatSession {
  id        String        @id @default(uuid())
  title     String        @default("New Chat")
  userId    String        @map("user_id")
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")
  messages  ChatMessage[]
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "chat_sessions_user_id_fkey")
  @@map("chat_sessions")
}

model ChatMessage {
  id        String      @id @default(uuid())
  sessionId String      @map("session_id")
  role      String
  content   String      @db.Text
  createdAt DateTime    @default(now()) @map("created_at")
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId], map: "chat_messages_session_id_fkey")
  @@map("chat_messages")
}

model App {
  id            String       @id @default(uuid())
  name          String
  category      String
  description   String       @db.Text
  iconStatic    String?      @map("icon_static")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")
  developer     String?
  downloadCount Int          @default(0) @map("download_count")
  viewCount     Int          @default(0) @map("view_count")
  versions      AppVersion[]

  @@map("apps")
}

model AppVersion {
  id             String   @id @default(uuid())
  appId          String   @map("app_id")
  version        String
  features       String?  @db.Text
  apkUrl         String   @map("apk_url")
  imageUrl       String?  @map("image_url")
  releaseDate    DateTime @default(now()) @map("release_date")
  createdAt      DateTime @default(now()) @map("created_at")
  androidVersion String?  @map("android_version")
  fileSize       BigInt?  @map("file_size")
  app            App      @relation(fields: [appId], references: [id], onDelete: Cascade)

  @@index([appId], map: "app_versions_app_id_fkey")
  @@map("app_versions")
}

model TempMailAccount {
  id        String            @id
  address   String            @unique
  password  String
  token     String?           @db.Text
  createdAt DateTime          @default(now()) @map("created_at")
  userId    String?           @map("user_id")
  user      User?             @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  TempMailMessage[]

  @@index([userId])
  @@map("temp_mail_accounts")
}

model TempMailMessage {
  id          String          @id
  msgid       String?         @db.Text
  fromName    String?
  fromAddress String?
  subject     String?         @db.Text
  intro       String?         @db.Text
  seen        Boolean         @default(false)
  createdAt   DateTime        @default(now()) @map("created_at")
  accountId   String          @map("account_id")
  account     TempMailAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@map("temp_mail_messages")
}

model QuickVaultItem {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  category  String
  label     String
  value     String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("quick_vault_items")
}

model TempMailStats {
  id               Int      @id @default(1)
  emailsGenerated  Int      @default(0) @map("emails_generated")
  messagesReceived Int      @default(0) @map("messages_received")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("temp_mail_stats")
}

model TelSession {
  id            String   @id @default(uuid())
  userId        String   @unique @map("user_id")
  accessAuth    String   @map("access_auth") @db.Text
  authorization String   @db.Text
  xDevice       String   @map("x_device") @db.Text
  hash          String   @db.Text
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  transactionId String   @map("transaction_id")
  webMsisdn     String   @map("web_msisdn")
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("tel_sessions")
}

model ApiKey {
  id        String        @id @default(uuid())
  userId    String        @map("user_id")
  name      String
  key       String        @unique
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")
  usages    ApiKeyUsage[]
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("api_keys")
}

model ApiKeyUsage {
  id               String   @id @default(uuid())
  apiKeyId         String   @map("api_key_id")
  endpoint         String
  method           String
  status           Int
  model            String?
  promptTokens     Int?     @default(0) @map("prompt_tokens")
  completionTokens Int?     @default(0) @map("completion_tokens")
  totalTokens      Int?     @default(0) @map("total_tokens")
  createdAt        DateTime @default(now()) @map("created_at")
  apiKey           ApiKey   @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)

  @@index([apiKeyId])
  @@index([model])
  @@map("api_key_usages")
}

model UserApiStats {
  id            String   @id @default(uuid())
  userId        String   @unique @map("user_id")
  totalRequests Int      @default(0) @map("total_requests")
  totalSuccess  Int      @default(0) @map("total_success")
  totalFailed   Int      @default(0) @map("total_failed")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_api_stats")
}

model LlmConsole {
  id        String   @id @default(uuid())
  userId    String   @unique @map("user_id")
  baseUrl   String   @map("base_url") @db.Text
  model     String   @db.VarChar(255)
  apiKey    String   @map("api_key") @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("llm_consoles")
}

model AiModel {
  id            String          @id
  name          String
  ownedBy       String          @map("owned_by")
  created       Int?
  status        String          @default("active")
  updatedAt     DateTime        @updatedAt @map("updated_at")
  isRestricted  Boolean         @default(false) @map("is_restricted")
  createdAt     DateTime        @default(now()) @map("created_at")
  baseUrl       String?         @map("base_url") @db.Text
  proxyPreset   String?         @default("DEFAULT") @map("proxy_preset")
  contextLength Int?            @default(128000) @map("context_length")
  allowedEmails AiModelAccess[]

  @@map("ai_models")
}

model AiModelAccess {
  id      Int     @id @default(autoincrement())
  modelId String  @map("model_id")
  email   String
  model   AiModel @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@unique([modelId, email])
  @@map("ai_model_access")
}

enum Role {
  MEMBER
  INSIDER
  PRO
  ULTRA
}
