generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Account {
  email         String    @id
  name          String
  refreshToken  String    @map("refresh_token")
  status        String    @default("active")
  totalMessages Int       @default(0) @map("total_messages")
  totalThreads  Int       @default(0) @map("total_threads")
  lastCheck     DateTime  @default(now()) @map("last_check")
  createdAt     DateTime  @default(now()) @map("created_at")
  messages      Message[]
  driveFiles    DriveFile[]

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("accounts")
}

model Message {
  id         String   @id
  subject    String
  from       String
  snippet    String   @db.Text
  body       String?  @db.MediumText
  receivedAt DateTime @default(now()) @map("received_at")
  accountId  String   @map("account_id")
  account    Account  @relation(fields: [accountId], references: [email], onDelete: Cascade)

  @@index([accountId])
  @@map("messages")
}

model DriveFile {
  id           String
  name         String
  mimeType     String
  size         String?
  iconLink     String?
  webViewLink  String?
  modifiedTime DateTime
  folderId     String   @default("root") @map("folder_id")

  accountId String   @map("account_id")
  account   Account  @relation(fields: [accountId], references: [email], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@id([id, folderId])
  @@index([accountId, folderId])
  @@map("drive_files")
}

model User {
  id                 String            @id @default(uuid())
  email              String            @unique
  password           String
  name               String?
  role               Role              @default(MEMBER)
  googleClientId     String?           @map("google_client_id") @db.Text
  googleClientSecret String?           @map("google_client_secret") @db.Text
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")
  accounts           Account[]
  airdrops           Airdrop[]
  airdropTasks       UserAirdropTask[]
  groqCredential     GroqCredential?
  chatSessions       ChatSession[]
  telegramUpdates    TelegramUpdate[]
  quickVaultItems    QuickVaultItem[]
  httpClientData     Json?             @map("http_client_data")

  @@map("users")
}

model TelegramUpdate {
  id        BigInt   @id // Telegram update_id
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  data      Json     // Full JSON payload
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("telegram_updates")
}

enum Role {
  MEMBER
  PRO
  ULTRA
}

model Airdrop {
  id              String    @id @default(uuid())
  name            String
  symbol          String?
  icon            String?
  status          String // e.g., "Confirmed", "Potential"
  statusDate      DateTime?
  score           Int? // Moni Score
  taskType        String? // e.g., "Testnet, Social"
  cost            String? // e.g., "$0"
  time            String? // e.g., "16 min"
  raise           String? // e.g., "$11.00M"
  stage           String? // e.g., "Alpha"
  projectType     String? // e.g., "Blockchain Infra"
  description     String?   @db.Text
  links           Json? // e.g., [{ name: "Website", url: "..." }]
  fundsAndBackers Json? // e.g., [{ name: "Pantera Capital", icon: "..." }]
  rewardDate      String? // e.g., "TBA"
  rewardType      String? // e.g., "Airdrop"

  userId          String?   @map("user_id")
  user            User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  isPublic        Boolean   @default(false) @map("is_public")
  publishStatus   String    @default("NONE") @map("publish_status")

  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")
  tasks     AirdropTask[]

  @@map("airdrops")
}

model AirdropTask {
  id          String    @id @default(uuid())
  title       String
  description String?   @db.Text
  category    String // e.g., "Social", "Mint NFT", "DePIN"
  deadline    DateTime?
  status      String    @default("Open") // "Open", "Closed"
  steps       Json?

  airdropId String  @map("airdrop_id")
  airdrop   Airdrop @relation(fields: [airdropId], references: [id], onDelete: Cascade)

  userProgress UserAirdropTask[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("airdrop_tasks")
}

model UserAirdropTask {
  id     String @id @default(uuid())
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  taskId String      @map("task_id")
  task   AirdropTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  completed   Boolean   @default(false)
  completedAt DateTime? @map("completed_at")

// Ensure a user can only have one progress record per task
  @@unique([userId, taskId])
  @@map("user_airdrop_tasks")
}

model SuggestedProject {
  id          String   @id @default(uuid())
  name        String
  link        String
  description String?  @db.Text
  sender      String   @default("Anonymous")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("suggested_projects")
}

model ApiEndpointStats {
  id        String   @id @default(uuid())
  method    String
  path      String   @unique
  hitCount  Int      @default(0) @map("hit_count")
  lastHit   DateTime @default(now()) @map("last_hit")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("api_endpoint_stats")
}

model MaintenanceConfig {
  id        String   @id @default(uuid())
  feature   String   @unique
  label     String
  enabled   Boolean  @default(false)
  message   String?
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("maintenance_configs")
}

model GlobalConfig {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String   @db.Text
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("global_configs")
}

model GroqCredential {
  id               String   @id @default(uuid())
  userId           String   @unique @map("user_id")
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  apiKey           String   @db.Text @map("api_key") // Stored encrypted
  promptTokens     Int      @default(0) @map("prompt_tokens")
  completionTokens Int      @default(0) @map("completion_tokens")
  totalTokens      Int      @default(0) @map("total_tokens")

  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("groq_credentials")
}

model ChatSession {
  id        String        @id @default(uuid())
  title     String        @default("New Chat")
  userId    String        @map("user_id")
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  ChatMessage[]

  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  @@map("chat_sessions")
}

model ChatMessage {
  id        String      @id @default(uuid())
  sessionId String      @map("session_id")
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  
  role      String      // 'user' or 'assistant'
  content   String      @db.Text
  
  createdAt DateTime    @default(now()) @map("created_at")

  @@map("chat_messages")
}

model App {
  id            String       @id @default(uuid())
  name          String
  developer     String?      // Developer or company name
  category      String
  description   String       @db.Text
  iconStatic    String?      @map("icon_static") // Direct link or empty string if using Telegram
  downloadCount Int          @default(0) @map("download_count")
  viewCount     Int          @default(0) @map("view_count")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")
  versions      AppVersion[]

  @@map("apps")
}

model AppVersion {
  id             String   @id @default(uuid())
  appId          String   @map("app_id")
  app            App      @relation(fields: [appId], references: [id], onDelete: Cascade)
  version        String
  androidVersion String?  @map("android_version") // e.g. "5.0+"
  features       String?  @db.Text // Can be stored as serialized JSON or multiline string
  apkUrl         String   @map("apk_url") // Telegram file URL or direct link
  imageUrl       String?  @map("image_url") // Telegram file URL or direct link
  releaseDate    DateTime @default(now()) @map("release_date")
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("app_versions")
}

model TempMailAccount {
  id        String   @id
  address   String   @unique
  password  String
  token     String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  messages  TempMailMessage[]

  @@map("temp_mail_accounts")
}

model TempMailMessage {
  id          String   @id
  msgid       String?  @db.Text
  fromName    String?
  fromAddress String?
  subject     String?  @db.Text
  intro       String?  @db.Text
  seen        Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")

  accountId   String          @map("account_id")
  account     TempMailAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@map("temp_mail_messages")
}

model QuickVaultItem {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category  String   // e.g. "social", "crypto", "exchange"
  label     String
  value     String   @db.Text // Encrypted value
  createdAt DateTime @default(now()) @map("created_at")
  
  @@index([userId])
  @@map("quick_vault_items")
}
