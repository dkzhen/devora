# Database
DATABASE_URL="mysql://user:password@localhost:3306/devora"

# AI Proxy Configuration
# Default Proxy (fallback)
AI_PROXY_URL=http://localhost:8317
AI_PROXY_TOKEN=your_default_token_here

# 9Router Proxy
ROUTER_PROXY_URL=http://your-router-proxy-url:port
ROUTER_PROXY_TOKEN=your_router_token_here

# CPA Proxy
CPA_PROXY_URL=http://your-cpa-proxy-url:port
CPA_PROXY_TOKEN=your_cpa_token_here

# Add more proxy presets as needed
# CUSTOM_PROXY_URL=http://your-custom-proxy:port
# CUSTOM_PROXY_TOKEN=your_custom_token

# Other configurations...
